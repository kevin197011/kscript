#!/usr/bin/env ruby
# frozen_string_literal: true

require 'http'
require 'json'

# class
class USDRate
  def run
    url = 'https://api.exchangerate-api.com/v4/latest/USD'

    begin
      response = HTTP.get(url)

      if response.status.success?
        data = response.parse(:json)
        json_body = JSON.pretty_generate(data)
        Rails.logger.debug json_body
      else
        Rails.logger.debug { "Failed to retrieve data: #{response.status}" }
      end
    rescue HTTP::Error => e
      Rails.logger.debug { "An error occurred: #{e.message}" }
    end
  end
end

USDRate.new.run if __FILE__ == $PROGRAM_NAME
